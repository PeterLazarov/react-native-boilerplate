{
  "name": "app-boilerplate",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prettier:check": "prettier --check .",
    "prettify": "prettier --write .",
    "verify": "npm run typecheck && npm run lint && npm run prettier:check"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-persist-client": "^5.59.0",
    "babel-preset-expo": "~54.0.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "i18next": "^23.15.0",
    "intl-pluralrules": "^2.0.1",
    "ky": "^1.7.0",
    "lucide-react-native": "^1.20.0",
    "nativewind": "^4.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.0.0",
    "react-native": "0.81.5",
    "react-native-mmkv": "^3.1.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "openapi-typescript": "^7.4.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "typescript": "~5.6.0"
  }
